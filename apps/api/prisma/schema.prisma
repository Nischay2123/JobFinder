// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  STUDENT
  FRESHER
  WORKING_PROFESSIONAL
}

model EmailVerification {
  id         String    @id @default(uuid())
  email      String    @unique
  tokenHash  String
  verifiedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  name             String
  passwordHash     String
  role             UserRole     @default(USER)
  isActive         Boolean      @default(true)
  refreshTokenHash String?
  lastLoginAt      DateTime?
  profile          UserProfile?
  syncs            UserSync[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model UserProfile {
  id                 String       @id @default(uuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String?
  lastName           String?
  phone              String?
  currentStatus      UserStatus?
  experienceYears    Float?
  preferredRoles     String[]
  preferredLocations Json         @default("[]")
  skills             String[]
  linkedinUrl        String?
  githubUrl          String?
  portfolioUrl       String?
  resumeUrl          String?
  isCompleted        Boolean      @default(false)
  experiences        Experience[]
  projects           Project[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now()) @updatedAt
}

model Experience {
  id             String       @id @default(uuid())
  profileId      String
  profile        UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyName    String
  role           String
  employmentType String?
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean      @default(false)
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
}

model Project {
  id           String       @id @default(uuid())
  profileId    String
  profile      UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  technologies String[]
  githubUrl    String?
  liveUrl      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now()) @updatedAt
}

enum JobSource {
  YC
  WELLFOUND
  INSTAHYRE
  CUTSHORT
  LINKEDIN
  NAUKRI
}

enum RemoteType {
  REMOTE
  HYBRID
  ONSITE
  UNKNOWN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum JobStatus {
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum ProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

enum SyncStatus {
  SYNC_REQUESTED
  FETCHING
  NORMALIZING
  COMPLETED
  FAILED
}

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  website   String?
  jobs      Job[]
  createdAt DateTime @default(now())
}

model Job {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id])
  source             JobSource
  sourceJobId        String?
  title              String
  description        String           @db.Text
  location           String?
  remoteType         RemoteType       @default(UNKNOWN)
  applyUrl           String
  experienceRequired String?
  employmentType     EmploymentType?
  salary             String?
  postedDate         DateTime?
  discoveredAt       DateTime         @default(now())
  expiresAt          DateTime?
  status             JobStatus        @default(ACTIVE)
  processingStatus   ProcessingStatus @default(PENDING)
  jobHash            String           @unique
  rawPayload         Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model UserSync {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       SyncStatus
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  jobsFound    Int        @default(0)
  jobsAdded    Int        @default(0)
  errorMessage String?
  createdAt    DateTime   @default(now())
}

model FailedJob {
  id           String    @id @default(uuid())
  jobType      String
  payload      Json
  errorMessage String
  stackTrace   String?
  replayCount  Int       @default(0)
  replayedAt   DateTime?
  createdAt    DateTime  @default(now())
}


